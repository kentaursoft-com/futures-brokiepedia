# Futures Brokiepedia - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# Cloudflare Worker (set via `wrangler secret put <NAME>`)
# ============================================================

# JWT signing secret (random 64-char string)
JWT_SECRET=

# SHA-256 hash of the admin password
# Generate: echo -n "yourpassword" | sha256sum
AUTH_PASSWORD_HASH=

# Allowed CORS origin for the frontend
ALLOWED_ORIGIN=https://futures.brokiepedia.com

# VPS daemon URL (must be HTTPS)
DAEMON_URL=https://daemon.brokiepedia.com

# VPS internal key for secure daemon communication
VPS_INTERNAL_KEY=

# DeepSeek API key for AI agents
DEEPSEEK_API_KEY=

# Telegram bot token for alerts
TELEGRAM_BOT_TOKEN=

# Binance API credentials
BINANCE_API_KEY=
BINANCE_SECRET_KEY=

# Turso/libSQL connection
TURSO_DB_URL=
TURSO_DB_TOKEN=

# Evaluation endpoint API key
EVAL_API_KEY=

# ============================================================
# VPS Daemon (set in docker-compose.prod.yml or .env)
# ============================================================
TRADING_MODE=paper
QUESTDB_HOST=localhost
QUESTDB_PORT=8812
CHROMADB_HOST=localhost
CHROMADB_PORT=8000
