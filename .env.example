# Futures Brokiepedia — Environment Variables
# Copy to .env and fill in your values

# Trading Mode
TRADING_MODE=paper

# API Keys
DEEPSEEK_API_KEY=your_deepseek_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Exchange API (Binance)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here

# LangSmith (optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_key_here

# Database
TURSO_DB_URL=libsql://your-db.aws-eu-west-1.turso.io
TURSO_DB_TOKEN=your_turso_token_here

# QuestDB (internal Docker network)
QUESTDB_HOST=questdb
QUESTDB_PORT=8812
QUESTDB_USER=admin
QUESTDB_PASSWORD=brokiepedia_quest_2026

# ChromaDB (internal Docker network)
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# VPS Daemon API (for Cloudflare Worker)
DAEMON_URL=http://your-vps-ip:8080
