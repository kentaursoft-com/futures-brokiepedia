# DeepSeek AI
DEEPSEEK_API_KEY=your_deepseek_api_key

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# VPS
VPS_URL=http://your_vps_ip:8000
VPS_INTERNAL_KEY=your_internal_api_key
DAEMON_URL=http://your_vps_ip:8000

# Cloudflare Pages
CLOUDFLARE_API_TOKEN=your_pages_upload_token
